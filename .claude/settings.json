{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "mcpServers": {
    "kiclaude": {
      "command": "kiclaude",
      "args": ["mcp", "stdio"],
      "description": "kiclaude MCP server — kc_* tools for KiCad project introspection and edits."
    }
  },
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(rustup *)",
      "Bash(wasm-pack *)",
      "Bash(pnpm *)",
      "Bash(uv *)",
      "Bash(kicad-cli *)",
      "Bash(kiclaude *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": []
  }
}
