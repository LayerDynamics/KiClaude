{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus that scrapes the OTel Collector (docs/observability/otel-collector-config.yaml, :8889)",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "kiclaude — Claude tool activity",
  "uid": "kiclaude-agent",
  "tags": ["kiclaude", "otel", "agent"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      },
      {
        "name": "tool",
        "label": "tool_name",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(calls_total{span_name=~\"agent.hook.*\"}, tool_name)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "p95 tool-call latency (NFR-006 SLO ≤ 800 ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 800 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, tool_name) (rate(duration_milliseconds_bucket{span_name=~\"agent.hook.*\", tool_name=~\"$tool\"}[5m])))",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Tool-call rate (calls/s by tool)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool_name) (rate(calls_total{span_name=\"agent.hook.pre_tool_use\", tool_name=~\"$tool\"}[5m]))",
          "legendFormat": "{{tool_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tool-call distribution (total)",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (tool_name) (calls_total{span_name=\"agent.hook.pre_tool_use\", tool_name=~\"$tool\"})",
          "legendFormat": "{{tool_name}}",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Overall p95 tool latency",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 800 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(duration_milliseconds_bucket{span_name=~\"agent.hook.*\"}[5m])))"
        }
      ]
    },
    {
      "id": 5,
      "title": "Total tool calls (rate)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(calls_total{span_name=\"agent.hook.pre_tool_use\"}[5m]))"
        }
      ]
    }
  ]
}
