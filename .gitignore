# Rust
target/
**/target/
*.rs.bk

# Node / TS
node_modules/
**/node_modules/
dist/
build/
.next/
.cache/
*.tsbuildinfo

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.venv/
.venv*/
venv/
.eggs/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
.coverage
htmlcov/

# uv
.uv-cache/

# wasm-pack outputs
pkg/
**/pkg/

# KiCad auxiliary project files pcbnew writes alongside .kicad_pcb on save —
# the .kicad_pcb itself is the load-bearing artifact; `.kicad_prl` is the
# per-user local prefs sidecar and `_filled.kicad_pro` files are
# auto-regenerated by the fixture script.
**/*.kicad_prl
**/*-backups/
**/fp-info-cache
**/auto-routes/
# Filled-fixture project sidecars (regenerated by generate_fixtures.py).
tests/golden/zones/*_filled.kicad_pro

# Local CLI caches / DBs
**/.cache/
**/library.db

# External reference checkouts under development/resources/kicad/ —
# these are clone-for-documentation repos (kicad-library, kicad-python,
# kicanvas, freerouting, KiKit, PcbDraw, tscircuit, etc.) with their
# own .git histories. They are NOT part of this project's source and
# would either pollute the tree (if vendored) or have to be tracked
# as submodules (which we deliberately aren't doing at M2). Ignore.
development/resources/kicad/*/

# OS junk
.DS_Store
**/.DS_Store
Thumbs.db

# IDE / editor cruft
.idea/
.vscode/
*.swp
*.swo
*~

# Local environment overrides
.env
.env.local
.env.*.local

# Session data the agent service writes per project under .kiclaude/sessions/
**/.kiclaude/sessions/

# Playwright artifacts that should regenerate per run
test-results/
**/test-results/
playwright-report/
**/playwright-report/

# Temporary fab artifacts
**/fab_out/
*.zip

# Coverage / profiling output
*.profraw
*.profdata
